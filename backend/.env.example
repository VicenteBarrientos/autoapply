ANTHROPIC_API_KEY=sk-ant-...
PORT=3000
# Shared secret between the backend and the extension.
# Set this to a random string (e.g. openssl rand -hex 32) and copy the same
# value into BACKEND_SECRET in extension/background.js.
AUTOAPPLY_SECRET=
# Optional: RapidAPI key for broader job search via JSearch (https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch)
JSEARCH_API_KEY=
